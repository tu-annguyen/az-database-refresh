{
  "name": "az-database-refresh",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "dev:api": "npm --workspace workers/api run dev",
    "build": "npm --workspaces --if-present run build",
    "test": "vitest run",
    "typecheck": "npm --workspaces --if-present run typecheck"
  },
  "workspaces": [
    "apps/*",
    "workers/*",
    "packages/*"
  ],
  "devDependencies": {
    "@types/node": "^20.14.12",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9",
    "wrangler": "^4.107.0"
  }
}
